# Base URL for the Hefest API.
#
# Leave empty for same-origin (production behind Traefik, and dev via the Vite
# proxy in vite.config.ts). Set to an absolute URL only for split deployments
# where the API is served from a different origin, e.g.:
#   VITE_API_URL=https://api.example.com
VITE_API_URL=
